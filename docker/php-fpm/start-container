#!/bin/bash

echo "➜ Ignore Permission Changes"
git config core.fileMode false

echo "➜ Set Correct Permissions"
chmod -R 777 storage

echo "➜ Ensure Local Config"
[[ -f config.php ]] || cp config-sample.php config.php

echo "➜ Install Composer Dependencies"
[[ -d vendor ]] || composer install

if [[ "${EA_SKIP_NPM_BOOTSTRAP:-0}" == "1" ]]; then
    echo "➜ Skip NPM Dependency Bootstrap"
else
    echo "➜ Install NPM Dependencies"
    [[ -d node_modules ]] || npm install
fi

if [[ "${EA_SKIP_ASSET_BUILD_BOOTSTRAP:-0}" == "1" ]]; then
    echo "➜ Skip Asset Build Bootstrap"
else
    echo "➜ Build Project Assets"
    [[ -d assets/vendor ]] || npx gulp compile
fi

echo "➜ Listen To Incoming Requests"
php-fpm
