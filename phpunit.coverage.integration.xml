<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="./vendor/phpunit/phpunit/phpunit.xsd"
    bootstrap="index.php"
    colors="true"
    cacheResult="false"
>
    <testsuites>
        <testsuite name="CoverageIntegrationShard">
            <file>./tests/Integration/Controllers/BookingControllerFlowTest.php</file>
            <file>./tests/Integration/Controllers/BookingCancellationControllerFlowTest.php</file>
            <file>./tests/Integration/Controllers/BookingReadAvailabilityControllerFlowTest.php</file>
            <file>./tests/Integration/Controllers/ApiReadControllerFlowTest.php</file>
        </testsuite>
    </testsuites>
    <coverage processUncoveredFiles="false">
        <include>
            <directory suffix=".php">./application/controllers</directory>
            <directory suffix=".php">./application/libraries</directory>
            <directory suffix=".php">./application/models</directory>
            <directory suffix=".php">./application/helpers</directory>
            <directory suffix=".php">./application/core</directory>
        </include>
    </coverage>
    <php>
        <server name="APP_ENV" value="testing"/>
    </php>
</phpunit>
