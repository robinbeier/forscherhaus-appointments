<?xml version="1.0"?>
<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.5/phpunit.xsd"
    bootstrap="index.php"
    colors="true"
    cacheResult="false"
    cacheDirectory=".phpunit.cache"
>
    <testsuites>
        <testsuite name="CoverageIntegrationShard">
            <directory suffix="Test.php">./tests/Unit/Controllers</directory>
            <directory suffix="Test.php">./tests/Unit/Helper</directory>
            <directory suffix="Test.php">./tests/Unit/Migrations</directory>
            <directory suffix="Test.php">./tests/Unit/Models</directory>
            <directory suffix="Test.php">./tests/Unit/Views</directory>
            <file>./tests/Unit/Libraries/AvailabilityBufferTest.php</file>
            <file>./tests/Unit/Libraries/DashboardHeatmapTest.php</file>
            <file>./tests/Unit/Libraries/DashboardMetricsTest.php</file>
            <file>./tests/Unit/Libraries/IcsFileTest.php</file>
            <file>./tests/Unit/Libraries/PdfRendererTest.php</file>
            <file>./tests/Unit/Libraries/ProviderUtilizationTest.php</file>
            <file>./tests/Integration/Controllers/BookingControllerFlowTest.php</file>
            <file>./tests/Integration/Controllers/BookingCancellationControllerFlowTest.php</file>
            <file>./tests/Integration/Controllers/BookingReadAvailabilityControllerFlowTest.php</file>
            <file>./tests/Integration/Controllers/ApiReadControllerFlowTest.php</file>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory suffix=".php">./application/controllers</directory>
            <directory suffix=".php">./application/libraries</directory>
            <directory suffix=".php">./application/models</directory>
            <directory suffix=".php">./application/helpers</directory>
            <directory suffix=".php">./application/core</directory>
        </include>
    </source>
    <php>
        <server name="APP_ENV" value="testing"/>
    </php>
</phpunit>
