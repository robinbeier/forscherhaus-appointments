# Copy to ".env.symphony.pilot" and fill with local pilot values.
# Do not commit real secrets.

# Required
SYMPHONY_LINEAR_API_KEY=replace-with-linear-api-key
SYMPHONY_LINEAR_PROJECT_SLUG=replace-with-linear-project-slug
SYMPHONY_CODEX_COMMAND=codex --app-server

# Pilot safety defaults (used by scripts/symphony/start_pilot.sh guardrails)
SYMPHONY_PILOT_APPROVAL_POLICY=on-request
SYMPHONY_PILOT_SANDBOX_MODE=workspace-write
