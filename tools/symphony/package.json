{
    "name": "@forscherhaus/symphony-pilot",
    "version": "0.1.0",
    "private": true,
    "description": "Symphony sidecar scaffold for forscherhaus-appointments",
    "type": "module",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "start": "node dist/cli.js",
        "dev": "tsx src/cli.ts",
        "test": "tsx --test src/**/*.test.ts",
        "test:conformance": "tsx --test src/workflow-config.test.ts src/template.test.ts src/workspace-manager.test.ts src/orchestrator.test.ts src/app-server-client.test.ts src/test-profiles.test.ts"
    },
    "dependencies": {
        "yaml": "^2.8.1"
    },
    "devDependencies": {
        "@types/node": "^22.13.14",
        "tsx": "^4.20.5",
        "typescript": "^5.8.2"
    }
}
