<?xml version="1.0"?>
<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.5/phpunit.xsd"
    bootstrap="tests/bootstrap.coverage-unit.php"
    colors="true"
    cacheResult="false"
    cacheDirectory=".phpunit.cache"
>
    <testsuites>
        <testsuite name="CoverageUnitShard">
            <file>./tests/Unit/Libraries/ApiRequestDtoFactoryTest.php</file>
            <file>./tests/Unit/Libraries/ApiRequestDtoFactoryWriteTest.php</file>
            <file>./tests/Unit/Libraries/AuthRequestDtoFactoryTest.php</file>
            <file>./tests/Unit/Libraries/BackofficeRequestDtoFactoryTest.php</file>
            <file>./tests/Unit/Libraries/BookingRequestDtoFactoryTest.php</file>
            <file>./tests/Unit/Libraries/CalendarRequestDtoFactoryTest.php</file>
            <file>./tests/Unit/Libraries/DashboardRequestDtoFactoryTest.php</file>
            <file>./tests/Unit/Libraries/IntegrationsRequestDtoFactoryTest.php</file>
            <file>./tests/Unit/Libraries/RequestNormalizerTest.php</file>
            <directory suffix="Test.php">./tests/Unit/Scripts</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory suffix=".php">./application/controllers</directory>
            <directory suffix=".php">./application/libraries</directory>
            <directory suffix=".php">./application/models</directory>
            <directory suffix=".php">./application/helpers</directory>
            <directory suffix=".php">./application/core</directory>
        </include>
    </source>
    <php>
        <server name="APP_ENV" value="testing"/>
    </php>
</phpunit>
