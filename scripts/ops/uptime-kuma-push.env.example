# Copy this file to the host-local path used by KUMA_PUSH_ENV_FILE.
# Production currently uses /root/backups/uptime-kuma-push.env.
# Keep all values in the host-local copy. Never commit real Push URLs.

KUMA_PUSH_URL_HOST_SERVICES=
KUMA_PUSH_URL_HOST_RESOURCES=
KUMA_PUSH_URL_OPS_JOBS=
KUMA_PUSH_URL_BACKUP_CREATION=
KUMA_PUSH_URL_APP_LOGS=
KUMA_PUSH_URL_PHP_FPM_LOGS=
KUMA_PUSH_URL_PDF_RENDERER_LOGS=
KUMA_PUSH_URL_PDF_EXPORT=
KUMA_PUSH_URL_SECURITY_SCANNER=

KUMA_HOST_SERVICES_LIST="apache2 php8.5-fpm mariadb docker fh-pdf-renderer"
KUMA_HOST_RESOURCES_DISK_PATH=/
KUMA_HOST_RESOURCES_DISK_USED_WARN_PERCENT=85
KUMA_HOST_RESOURCES_MEM_USED_WARN_PERCENT=90
KUMA_HOST_RESOURCES_LOAD_WARN_PER_CORE=4

KUMA_OPS_JOBS_VERIFY_FILE=/root/backups/easyappointments/last_verify_success.utc
KUMA_OPS_JOBS_MAX_VERIFY_AGE_MINUTES=1440

KUMA_BACKUP_CREATION_MARKER_FILE=/root/backups/easyappointments/last_backup_success.utc
KUMA_BACKUP_CREATION_MAX_AGE_MINUTES=1440

KUMA_APP_ROOT=/var/www/html/easyappointments
KUMA_APP_LOG_IGNORE_REGEX=

KUMA_PHP_FPM_SERVICE_NAME=php8.5-fpm
KUMA_PDF_RENDERER_SERVICE_NAME=fh-pdf-renderer

KUMA_PDF_EXPORT_BASE_URL=http://localhost
KUMA_PDF_EXPORT_INDEX_PAGE=index.php
KUMA_PDF_EXPORT_CREDENTIALS_FILE=/etc/fh/release-gate-admin.env
KUMA_PDF_EXPORT_PDF_HEALTH_URL=http://127.0.0.1:3003/healthz
