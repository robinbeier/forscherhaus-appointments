#!/usr/bin/env bash
set -euo pipefail

# managed-by-forscherhaus-prepush
if [[ "${SKIP_PREPUSH:-0}" == "1" ]]; then
    echo "SKIP_PREPUSH=1 detected - skipping pre-push hook."
    exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if [[ "${PRE_PUSH_FULL:-0}" == "1" ]]; then
    PRE_PR_BASE_REF="${PRE_PR_BASE_REF:-main}" ./scripts/ci/pre_pr_full.sh
else
    PRE_PR_BASE_REF="${PRE_PR_BASE_REF:-main}" ./scripts/ci/pre_pr_quick.sh
fi
