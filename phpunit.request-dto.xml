<?xml version="1.0"?>
<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.5/phpunit.xsd"
    bootstrap="./tests/bootstrap_request_dto.php"
    colors="true"
    cacheResult="false"
    cacheDirectory=".phpunit.cache"
>
    <testsuites>
        <testsuite name="RequestDto">
            <file>./tests/Unit/Libraries/RequestNormalizerTest.php</file>
            <file>./tests/Unit/Libraries/BookingRequestDtoFactoryTest.php</file>
            <file>./tests/Unit/Libraries/DashboardRequestDtoFactoryTest.php</file>
            <file>./tests/Unit/Libraries/ApiRequestDtoFactoryTest.php</file>
        </testsuite>
    </testsuites>
    <php>
        <server name="APP_ENV" value="testing"/>
    </php>
</phpunit>
