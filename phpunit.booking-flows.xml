    xsi:noNamespaceSchemaLocation="./vendor/phpunit/phpunit/phpunit.xsd"
    bootstrap="index.php"
    colors="true"
    cacheResult="false"
>
    <testsuites>
        <testsuite name="BookingControllerFlows">
            <file>./tests/Integration/Controllers/BookingControllerFlowTest.php</file>
